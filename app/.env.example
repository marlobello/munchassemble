# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_APPLICATION_ID=your-application-id-here
DISCORD_GUILD_ID=your-guild-id-here          # optional: restrict command registration to one guild (dev)

# ─── Azure Cosmos DB ───────────────────────────────────────────────────────────
# For local dev: connection string auth. In production use Managed Identity.
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_DATABASE=munchassemble
# Only needed for local dev (no Managed Identity):
COSMOS_KEY=your-cosmos-key-here

# ─── Azure Key Vault (production only) ────────────────────────────────────────
# When KEY_VAULT_NAME is set, secrets are loaded from Key Vault at startup.
KEY_VAULT_NAME=

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Analytics web app (Phase 4, ADR-0006) ───────────────────────────────────
# Discord OAuth2 application credentials (create an OAuth app in the Discord dev portal).
DISCORD_OAUTH_CLIENT_ID=your-oauth-client-id
# Secret — in production loaded from Key Vault as `discord-oauth-client-secret`.
DISCORD_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# HMAC secret for signing session cookies — in production loaded from Key Vault as `web-session-secret`.
WEB_SESSION_SECRET=a-long-random-string
# Public base URL used to build the OAuth redirect URI (redirect = WEB_BASE_URL + /auth/callback).
WEB_BASE_URL=http://localhost:8080
WEB_PORT=8080

