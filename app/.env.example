# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_APPLICATION_ID=your-application-id-here
DISCORD_GUILD_ID=your-guild-id-here          # optional: restrict command registration to one guild (dev)

# ─── Azure Cosmos DB ───────────────────────────────────────────────────────────
# For local dev: connection string auth. In production use Managed Identity.
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_DATABASE=munchassemble
# Only needed for local dev (no Managed Identity):
COSMOS_KEY=your-cosmos-key-here

# ─── Azure Key Vault (production only) ────────────────────────────────────────
# When KEY_VAULT_NAME is set, secrets are loaded from Key Vault at startup.
KEY_VAULT_NAME=

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
